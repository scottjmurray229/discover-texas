---
import BaseLayout from '../../layouts/BaseLayout.astro';
import Breadcrumb from '../../components/Breadcrumb.astro';
import EmailCapture from '../../components/EmailCapture.astro';
import FAQ from '../../components/FAQ.astro';

const breadcrumbs = [
  { name: 'Home', url: '/' },
  { name: 'Texas Festival Calendar', url: '/festivals/' },
];

const pageTitle = 'Texas Festival Calendar 2026 — Events Worth Planning Your Trip Around';
const pageDescription = "SXSW, Austin City Limits, the Houston Rodeo, the State Fair of Texas, and San Antonio Fiesta — Texas hosts some of the world's most distinctive festivals. Here's what to know before you go.";

const festivals = [
  {
    name: 'SXSW — South by Southwest',
    location: 'Austin',
    dates: 'March (10 days)',
    description: 'The most important convergence of music, film, tech, and culture in the United States — and arguably the world. Austin becomes a 400,000-person laboratory for what\'s next for ten days in March. The official SXSW badge ($1,200–1,800) gets you into official panels, film screenings, and showcases. But the free shows — thousands of them, in every bar and parking lot in the city — are often where the real discoveries happen. First-timers: focus on music rather than trying to do everything. The 6th Street to Red River corridor is ground zero.',
    tag: 'World-Class',
    gradient: 'linear-gradient(135deg, #1B5E20 0%, #283593 100%)',
  },
  {
    name: 'Austin City Limits Music Festival',
    location: 'Austin (Zilker Park)',
    dates: 'October (two weekends)',
    description: 'ACL runs over two consecutive weekends in October in Zilker Park, steps from the Colorado River — one of the best festival sites in the country. Eight stages, 130+ artists, 75,000 attendees per day. The lineup is eclectic and consistently excellent — headliners cross rock, hip-hop, country, pop, and R&B. The Austin food scene deploys a strong vendor presence. Weekend passes $295–375; 3-day passes available. October in Austin is perfect festival weather: 75–85°F, low humidity, golden light.',
    tag: 'Must-Attend',
    gradient: 'linear-gradient(135deg, #E65100 0%, #FF9800 100%)',
  },
  {
    name: 'Houston Livestock Show & Rodeo',
    location: 'Houston (NRG Center)',
    dates: 'Late February – mid March (3 weeks)',
    description: 'The world\'s largest livestock show and rodeo by attendance — 2.5 million people over three weeks in Houston. Champions of every livestock category are crowned, barbecue competitions draw champions from across the state, and the evening concerts feature country, hip-hop, Latin, and pop headliners at NRG Stadium. The mutton bustin\' (young children riding sheep) is a crowd highlight. One of the most distinctly Texan events anywhere — combine with the Houston Museum District for a complete Houston week.',
    tag: 'World\'s Largest Rodeo',
    gradient: 'linear-gradient(135deg, #7B1F1F 0%, #C62828 100%)',
  },
  {
    name: 'State Fair of Texas',
    location: 'Dallas (Fair Park)',
    dates: 'Late September – mid October (24 days)',
    description: 'The biggest state fair in the country by attendance — 2 million+ visitors over 24 days. The Texas Star Ferris wheel (212 feet) and Big Tex (the world\'s largest cowboy, at 55 feet) are the landmarks. The fried food competition is a genuine cultural institution — fried butter, fried Oreos, fried Snickers, and whatever the current year\'s winner brings. Auto show, livestock competitions, the Cotton Bowl football game on opening weekend. Fair Park itself is a National Historic Landmark with 1930s Art Deco exhibition buildings. Admission $18–22.',
    tag: 'Biggest State Fair',
    gradient: 'linear-gradient(135deg, #BF360C 0%, #FF5722 100%)',
  },
  {
    name: 'San Antonio Fiesta',
    location: 'San Antonio',
    dates: 'April (10 days, around April 21)',
    description: 'The largest civic festival in Texas — a 10-day city-wide celebration with 100+ events including three major parades, the Fiesta Oyster Bake (50,000 attendees), A Night in Old San Antonio (four evenings in La Villita Historic District), and the Battle of Flowers parade that started in 1891 to honor the Alamo heroes. 3.5 million people attend Fiesta events over 10 days. Many events are free or cheap. The River Walk fills with food, music, and street performers for the entire run. San Antonio during Fiesta is an entirely different city.',
    tag: '3.5M Attendees',
    gradient: 'linear-gradient(135deg, #880E4F 0%, #E91E63 100%)',
  },
  {
    name: 'Galveston Mardi Gras',
    location: 'Galveston',
    dates: 'February (Fat Tuesday + surrounding weekends)',
    description: 'Galveston\'s Mardi Gras is the third-largest in the United States after New Orleans and Miami — a genuine Gulf Coast celebration with parades, bead-throwing, masquerade balls, and a Mardi Gras Museum at the historic Moody Mansion. The Galveston tradition dates to 1867 and has survived hurricanes, Prohibition, and everything else the Gulf of Mexico throws at this barrier island. The parade route runs along the Strand (the Victorian commercial district). Free to watch; buy tickets for the Moody Mansion Mardi Gras Ball.',
    tag: 'Mardi Gras',
    gradient: 'linear-gradient(135deg, #4A148C 0%, #F9A825 100%)',
  },
  {
    name: 'Rio Grande Valley International Music Festival',
    location: 'McAllen',
    dates: 'November',
    description: 'One of the Southwest\'s most underrated classical music events — the RGV International Music Festival in McAllen brings world-class orchestral and chamber music to South Texas, drawing musicians and audiences from across the Texas-Mexico border region. The programming reflects the valley\'s genuine bicultural character. Multiple venues, several ticketed events and free performances. McAllen is worth the trip from San Antonio or Corpus Christi — combine with the National Butterfly Center, which sits on the Rio Grande.',
    tag: 'Classical Music',
    gradient: 'linear-gradient(135deg, #006064 0%, #00BCD4 100%)',
  },
  {
    name: 'Texas Monthly BBQ Festival',
    location: 'Austin (Fiesta Gardens)',
    dates: 'October',
    description: 'Texas Monthly\'s annual barbecue celebration brings together the pitmasters behind the magazine\'s coveted Texas BBQ rankings for one day of wood-smoked beef, pork, and brisket. Access to Franklin, Snow\'s, Pecan Lodge, La Barbecue, and a dozen other legends simultaneously — normally a 3-hour wait condensed into one afternoon. Tickets sell out in minutes and go on sale months ahead. Watch the Texas Monthly website obsessively in summer for the sale announcement.',
    tag: 'Food & BBQ',
    gradient: 'linear-gradient(135deg, #4E342E 0%, #8D6E63 100%)',
  },
];
---
<BaseLayout
  title={pageTitle}
  description={pageDescription}
  pageType="destination"
  breadcrumbs={breadcrumbs}
>

<style>
  .fest-hero {
    position: relative;
    min-height: 70vh;
    display: flex;
    align-items: flex-end;
    padding: 0 var(--space-6) 60px;
    overflow: hidden;
    background: linear-gradient(135deg, #1B0000 0%, #7B1F1F 50%, #1B5E20 100%);
  }
  .fest-hero-video { position: absolute; inset: 0; width: 100%; height: 100%; object-fit: cover; opacity: 0.35; }
  .fest-hero-gradient { position: absolute; inset: 0; background: linear-gradient(to top, rgba(27,0,0,0.95) 0%, rgba(27,0,0,0.3) 60%, transparent 100%); }
  .fest-hero-content { position: relative; z-index: 2; max-width: 760px; }
  .fest-hero-eyebrow { font-size: 0.72rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.12em; color: #FF9800; margin-bottom: var(--space-3); }
  .fest-hero-title { font-size: clamp(2rem, 5vw, 3.2rem); font-weight: var(--weight-bold); color: #fff; line-height: 1.15; margin: 0 0 var(--space-4); }
  .fest-hero-subtitle { font-size: clamp(1rem, 2vw, 1.2rem); color: rgba(255,255,255,0.82); line-height: 1.6; margin: 0 0 var(--space-6); max-width: 600px; }
  .fest-hero-meta { display: flex; gap: var(--space-6); flex-wrap: wrap; }
  .fest-hero-meta-item { display: flex; flex-direction: column; gap: 2px; }
  .fest-hero-meta-label { font-size: 0.68rem; font-weight: var(--weight-semibold); text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.5); }
  .fest-hero-meta-value { font-size: 1.4rem; font-weight: var(--weight-bold); color: #fff; }

  .fest-personal { padding-block: var(--space-8); }
  .fest-personal-quote { max-width: 720px; margin: 0 auto; padding: var(--space-6) var(--space-8); border-left: 4px solid #C62828; background: var(--color-sky, #fff8f3); border-radius: 0 12px 12px 0; }
  .fest-personal-quote p { font-size: var(--text-body, 1.05rem); color: var(--color-heading, #1a2332); line-height: 1.7; font-style: italic; margin-bottom: var(--space-3); }
  .fest-personal-quote cite { font-size: 0.85rem; color: #C62828; font-weight: var(--weight-semibold); font-style: normal; }

  .fest-section { padding: var(--space-6) 0 var(--space-10); }
  .fest-section-heading { font-size: clamp(1.4rem, 3vw, 2rem); font-weight: var(--weight-bold); color: var(--color-deep-night, #1a2332); margin: 0 0 var(--space-2); text-align: center; }
  .fest-section-sub { font-size: 1rem; color: var(--color-slate, #5a6a7a); text-align: center; margin: 0 0 var(--space-8); }

  .fest-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(320px, 1fr)); gap: var(--space-6); }
  .fest-card { border-radius: 20px; overflow: hidden; background: var(--color-white, #fff); box-shadow: 0 4px 20px rgba(0,0,0,0.07); transition: transform 0.3s ease, box-shadow 0.3s ease; display: flex; flex-direction: column; }
  .fest-card:hover { transform: translateY(-6px); box-shadow: 0 12px 40px rgba(0,0,0,0.12); }
  .fest-card-header { padding: var(--space-5) var(--space-5) var(--space-4); min-height: 130px; display: flex; flex-direction: column; justify-content: flex-end; }
  .fest-card-tag { display: inline-block; font-size: 0.65rem; font-weight: var(--weight-bold); text-transform: uppercase; letter-spacing: 0.1em; color: rgba(255,255,255,0.9); background: rgba(255,255,255,0.18); backdrop-filter: blur(4px); padding: 3px 10px; border-radius: 20px; margin-bottom: var(--space-2); width: fit-content; }
  .fest-card-name { font-size: 1.15rem; font-weight: var(--weight-bold); color: #fff; line-height: 1.3; margin: 0 0 4px; }
  .fest-card-location { font-size: 0.78rem; color: rgba(255,255,255,0.75); font-weight: var(--weight-medium); }
  .fest-card-body { padding: var(--space-4) var(--space-5) var(--space-5); flex: 1; display: flex; flex-direction: column; gap: var(--space-3); }
  .fest-card-dates { display: flex; align-items: center; gap: var(--space-2); font-size: 0.8rem; font-weight: var(--weight-semibold); color: #C62828; }
  .fest-card-dates::before { content: ''; display: inline-block; width: 6px; height: 6px; border-radius: 50%; background: #C62828; flex-shrink: 0; }
  .fest-card-desc { font-size: 0.88rem; color: var(--color-body, #3d4d5e); line-height: 1.65; flex: 1; }

  .fest-tips { padding: var(--space-8) 0; background: linear-gradient(135deg, #1B0000 0%, #7B1F1F 100%); }
  .fest-tips-inner { max-width: 820px; margin: 0 auto; padding: 0 var(--space-6); }
  .fest-tips-heading { font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: var(--weight-bold); color: #fff; margin: 0 0 var(--space-6); text-align: center; }
  .fest-tips-grid { display: grid; grid-template-columns: repeat(auto-fill, minmax(240px, 1fr)); gap: var(--space-4); }
  .fest-tip-card { background: rgba(255,255,255,0.08); border: 1px solid rgba(255,255,255,0.12); border-radius: 14px; padding: var(--space-4) var(--space-5); }
  .fest-tip-icon { font-size: 1.5rem; margin-bottom: var(--space-2); }
  .fest-tip-title { font-size: 0.9rem; font-weight: var(--weight-bold); color: #fff; margin-bottom: var(--space-2); }
  .fest-tip-text { font-size: 0.82rem; color: rgba(255,255,255,0.72); line-height: 1.6; }

  .fest-cta-section { padding: var(--space-8) 0; }
  .fest-cta-card { background: linear-gradient(135deg, #1B0000 0%, #1B5E20 100%); border-radius: 20px; padding: var(--space-8) var(--space-6); text-align: center; color: #fff; }
  .fest-cta-heading { font-size: clamp(1.3rem, 3vw, 1.8rem); font-weight: var(--weight-bold); margin: 0 0 var(--space-3); color: #fff; }
  .fest-cta-text { font-size: 1rem; color: rgba(255,255,255,0.75); max-width: 520px; margin: 0 auto var(--space-5); line-height: 1.6; }
  .fest-cta-button { display: inline-block; background: #FF9800; color: #1B0000; font-size: 0.9rem; font-weight: var(--weight-semibold); padding: 12px 28px; border-radius: 40px; text-decoration: none; transition: background 0.2s ease, transform 0.2s ease; }
  .fest-cta-button:hover { background: #F57C00; transform: translateY(-2px); }

  .fest-crosslinks { padding: 0 0 var(--space-10); }
  .fest-crosslinks-heading { font-size: 1.1rem; font-weight: var(--weight-bold); color: var(--color-deep-night, #1a2332); text-align: center; margin: 0 0 var(--space-4); }
  .fest-crosslinks-grid { display: grid; grid-template-columns: repeat(2, 1fr); gap: var(--space-4); max-width: 640px; margin: 0 auto; }
  .fest-crosslink-card { display: flex; flex-direction: column; align-items: center; gap: var(--space-2); padding: var(--space-5) var(--space-4); background: var(--color-white, #fff); border: 1px solid rgba(0,0,0,0.06); border-radius: 16px; text-decoration: none; color: inherit; text-align: center; transition: transform 0.3s ease, box-shadow 0.3s ease; }
  .fest-crosslink-card:hover { transform: translateY(-4px); box-shadow: 0 8px 24px rgba(0,0,0,0.08); }
  .fest-crosslink-icon { font-size: 1.8rem; }
  .fest-crosslink-label { font-size: 0.95rem; font-weight: var(--weight-bold); color: var(--color-deep-night, #1a2332); }
  .fest-crosslink-desc { font-size: 0.78rem; color: var(--color-slate, #5a6a7a); line-height: 1.4; }

  @media (max-width: 640px) {
    .fest-crosslinks-grid { grid-template-columns: 1fr; }
    .fest-grid { grid-template-columns: 1fr; }
    .fest-hero { padding: 0 var(--space-4) 40px; min-height: 55vh; }
  }

  .reveal { opacity: 0; transform: translateY(24px); transition: opacity 0.6s ease, transform 0.6s ease; }
  .reveal.visible { opacity: 1; transform: none; }
</style>

  <header class="fest-hero">
    <video class="fest-hero-video" autoplay muted loop playsinline preload="metadata">
      <source src="/videos/pillar/festivals-hero.mp4" type="video/mp4" />
    </video>
    <div class="fest-hero-gradient"></div>
    <div class="fest-hero-content">
      <p class="fest-hero-eyebrow">Texas Events & Festivals</p>
      <h1 class="fest-hero-title">Texas Festival Calendar 2026</h1>
      <p class="fest-hero-subtitle">SXSW, the Houston Rodeo, the State Fair of Texas, San Antonio Fiesta — Texas doesn't just do things big. It does them in a way that's impossible to replicate anywhere else on earth.</p>
      <div class="fest-hero-meta">
        <div class="fest-hero-meta-item">
          <span class="fest-hero-meta-label">Events</span>
          <span class="fest-hero-meta-value">8</span>
        </div>
        <div class="fest-hero-meta-item">
          <span class="fest-hero-meta-label">Peak Season</span>
          <span class="fest-hero-meta-value">Mar / Oct</span>
        </div>
        <div class="fest-hero-meta-item">
          <span class="fest-hero-meta-label">Best City</span>
          <span class="fest-hero-meta-value">Austin</span>
        </div>
      </div>
    </div>
  </header>

  <div class="container-content">
    <Breadcrumb items={breadcrumbs} />
  </div>

  <section class="fest-personal reveal">
    <div class="container-content">
      <blockquote class="fest-personal-quote">
        <p>Texas festivals have an authenticity problem that they don't actually have — I mean people assume that because everything is supersized, it must be commercially manufactured. But San Antonio Fiesta has been running since 1891. The Houston Rodeo is genuinely the world's largest. SXSW started as a scrappy music showcase that Austin's Sixth Street scene basically grew up around. Even the State Fair, with its 55-foot Big Tex and Ferris wheel and fried butter competition, is a genuine Texas institution that 2 million people attend because they want to, not because they have to. The scale is real. The tradition is real. Come in March or October and you'll understand.</p>
        <cite>— Scott Murray, Discover Texas</cite>
      </blockquote>
    </div>
  </section>

  <section class="fest-section reveal">
    <div class="container-content">
      <h2 class="fest-section-heading">Texas's Top Festivals & Events</h2>
      <p class="fest-section-sub">March and October are the peak months — spring and fall bring perfect weather and Texas's biggest events simultaneously.</p>
      <div class="fest-grid">
        {festivals.map((fest) => (
          <div class="fest-card reveal">
            <div class="fest-card-header" style={`background: ${fest.gradient};`}>
              {fest.tag && <span class="fest-card-tag">{fest.tag}</span>}
              <h3 class="fest-card-name">{fest.name}</h3>
              <div class="fest-card-location">{fest.location}</div>
            </div>
            <div class="fest-card-body">
              <div class="fest-card-dates">{fest.dates}</div>
              <p class="fest-card-desc">{fest.description}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <section class="fest-tips reveal">
    <div class="fest-tips-inner">
      <h2 class="fest-tips-heading">Scott's Texas Festival Tips</h2>
      <div class="fest-tips-grid">
        <div class="fest-tip-card">
          <div class="fest-tip-icon">&#127925;</div>
          <div class="fest-tip-title">SXSW: free shows over badges</div>
          <p class="fest-tip-text">A SXSW badge runs $1,200–1,800 and gets you into official programming. The free shows — in bars, on parking lots, at unofficial showcases — are where most of the best music happens. Focus on the Red River Cultural District. The unofficial "SXSW" experience at Austin's 6th Street is free and often better than the official conference.</p>
        </div>
        <div class="fest-tip-card">
          <div class="fest-tip-icon">&#129399;</div>
          <div class="fest-tip-title">Houston Rodeo: weeknight for less crowds</div>
          <p class="fest-tip-text">The Houston Livestock Show & Rodeo runs 20+ days. Weeknight shows are less crowded and tickets are cheaper. The livestock competitions happen during the day before the evening rodeo and concert — arrive by noon to see the full experience. The carnival and barbecue cook-off are worth extra time beyond just the rodeo performance.</p>
        </div>
        <div class="fest-tip-card">
          <div class="fest-tip-icon">&#127999;</div>
          <div class="fest-tip-title">State Fair: try one fried thing you've never heard of</div>
          <p class="fest-tip-text">The Big Tex Choice Awards crown the best new fried food each year. Try whatever won — fried butter, fried cookie dough, fried Thanksgiving dinner. This is the entire point of the State Fair food culture. Also: the Fletcher's corn dog is a Fair Park institution and worth the line.</p>
        </div>
        <div class="fest-tip-card">
          <div class="fest-tip-icon">&#128081;</div>
          <div class="fest-tip-title">San Antonio Fiesta: A Night in Old San Antonio</div>
          <p class="fest-tip-text">NIOSA — A Night in Old San Antonio — runs four evenings in La Villita Historic Arts Village during Fiesta. 10,000+ people wander through food booths representing San Antonio's cultural heritage: Mexican, German, Tejano, Native American, and more. Tickets around $20/evening. This is the most intimate and authentic Fiesta experience.</p>
        </div>
        <div class="fest-tip-card">
          <div class="fest-tip-icon">&#127868;</div>
          <div class="fest-tip-title">ACL Festival: second weekend is the move</div>
          <p class="fest-tip-text">Austin City Limits runs over two weekends with nearly identical lineups. The second weekend typically has smaller crowds as out-of-towners schedule the first weekend. Single-day tickets go on sale after initial weekend passes and can be combined with exploring Austin's less-crowded neighborhoods while everyone else is at the festival.</p>
        </div>
        <div class="fest-tip-card">
          <div class="fest-tip-icon">&#127790;</div>
          <div class="fest-tip-title">Galveston Mardi Gras: stay on the island</div>
          <p class="fest-tip-text">Galveston's Mardi Gras is best experienced by staying on the island rather than day-tripping from Houston. The evening parades, Strand District bars, and Mardi Gras balls are the core experience — and the island has excellent seafood restaurants, historic Victorian architecture, and beach access outside of parade hours.</p>
        </div>
      </div>
    </div>
  </section>

  <section class="fest-cta-section reveal">
    <div class="container-content">
      <div class="fest-cta-card">
        <h2 class="fest-cta-heading">Plan Your Texas Festival Trip</h2>
        <p class="fest-cta-text">Build a custom Texas itinerary combining Austin, San Antonio, Houston, and Dallas around the festivals you want to attend — with BBQ trails, live music, and national parks built in.</p>
        <a href="/plan/" class="fest-cta-button">Start Planning &rarr;</a>
      </div>
    </div>
  </section>

  <FAQ items={[
    { question: "What is SXSW and do I need a badge to attend?", answer: "South by Southwest (SXSW) is a 10-day convergence of music, film, tech, and culture held in Austin every March. Official badges ($1,200–1,800) provide access to all official showcases, screenings, and panels. But much of the most interesting music programming happens at free shows — 'unofficial' showcases, brand activations, and bar shows on 6th Street and Red River that run simultaneously. Many first-time visitors have a great SXSW experience without a badge by focusing on the free music events." },
    { question: "When is the Houston Livestock Show and Rodeo?", answer: "The Houston Livestock Show & Rodeo runs approximately 20 days from late February through mid-March at NRG Center and NRG Stadium. It's the world's largest livestock show and rodeo by attendance — 2.5 million people over the run. Daily livestock shows and competitions happen during the day; professional rodeo and a major concert headline each evening. Tickets $25–150 depending on event and seating. Buy early for headliner concerts." },
    { question: "What is San Antonio Fiesta?", answer: "Fiesta is a 10-day civic celebration in San Antonio in April (around April 21, the anniversary of the Battle of San Jacinto and the Alamo) with 100+ official events. Key highlights: Battle of Flowers Parade, Texas Cavaliers River Parade, A Night in Old San Antonio (NIOSA) at La Villita, and the Fiesta Oyster Bake. 3.5 million people attend Fiesta events. Many events are free; NIOSA tickets run around $20 per evening." },
    { question: "How do I attend Austin City Limits Music Festival?", answer: "ACL Fest takes place in Zilker Park, Austin over two consecutive weekends in October. 3-day weekend passes ($295–375) go on sale in spring, often selling out quickly. Single-day tickets become available later but are limited. The festival grounds are walkable from downtown Austin — many attendees stay in Austin hotels rather than on-site camping, using rideshare or walking to the park. October weather in Austin is ideal: 75–85°F, low humidity." },
    { question: "What should I eat at the State Fair of Texas?", answer: "The State Fair runs on fried food creativity — the Big Tex Choice Awards crown the best new fried food each year, and the winner becomes the most-photographed item at the fair. Fletcher's Corny Dogs have been a Fair Park institution since 1942 and are considered the definitive State Fair food. The Midway Cafe and Agriculture Building have more traditional fair food. The BBQ competition (Rotary Club's Big Tex BBQ) is also excellent." },
    { question: "What's the best time of year to visit Texas for festivals?", answer: "March and October are peak Texas festival months. March brings SXSW in Austin and the Houston Rodeo. October brings ACL Fest in Austin and the State Fair of Texas in Dallas. Both months have ideal weather — 65–85°F, low humidity in most cities. February adds Galveston Mardi Gras and the Houston Rodeo kickoff. April brings San Antonio Fiesta. The summer months (June–August) see temperatures over 100°F in most of Texas — outdoor festivals thin out significantly." },
  ]} />

  <div class="container-content reveal" style="padding-bottom: var(--space-6);">
    <EmailCapture
      leadMagnet="Get the Texas Festival Planning Guide"
      description="Month-by-month Texas events breakdown with tips, logistics, and how to combine Austin, San Antonio, Houston, and Dallas in one epic trip."
      bullets={[
        'SXSW free show strategy — how to experience it without a $1,500 badge',
        'Houston Rodeo insider guide — what to see beyond the concert',
        'State Fair of Texas food champion tracker — the best fried things',
        'Combining Austin, San Antonio, and Hill Country in one trip',
      ]}
      guideTag="pillar-festivals-texas"
    />
  </div>

  <section class="fest-crosslinks reveal">
    <div class="container-content">
      <h3 class="fest-crosslinks-heading">Keep Exploring Texas</h3>
      <div class="fest-crosslinks-grid">
        <a href="/cuisine/" class="fest-crosslink-card">
          <span class="fest-crosslink-icon">&#128293;</span>
          <span class="fest-crosslink-label">Texas BBQ Guide</span>
          <span class="fest-crosslink-desc">The Texas BBQ trail — from Franklin to Snow's, ranked and reviewed</span>
        </a>
        <a href="/destinations/" class="fest-crosslink-card">
          <span class="fest-crosslink-icon">&#127965;</span>
          <span class="fest-crosslink-label">All Destinations</span>
          <span class="fest-crosslink-desc">Every Texas destination explored with honest reviews</span>
        </a>
        <a href="/history/" class="fest-crosslink-card">
          <span class="fest-crosslink-icon">&#127981;</span>
          <span class="fest-crosslink-label">Texas History</span>
          <span class="fest-crosslink-desc">The Alamo, Republic of Texas, and the history behind the festivals</span>
        </a>
